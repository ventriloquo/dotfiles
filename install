#!/bin/sh

cp -r .config ~/ &&

sudo apt update && sudo apt install curl wget gpg &&

# Librewolf
sudo apt install extrepo -y &&
sudo extrepo enable librewolf &&

# Deno
curl -fsSL https://deno.land/install.sh | sh

# Lazygit
LAZYGIT_VERSION=$(curl -s "https://api.github.com/repos/jesseduffield/lazygit/releases/latest" | \grep -Po '"tag_name": *"v\K[^"]*')
curl -Lo lazygit.tar.gz "https://github.com/jesseduffield/lazygit/releases/download/v${LAZYGIT_VERSION}/lazygit_${LAZYGIT_VERSION}_Linux_x86_64.tar.gz"
tar xf lazygit.tar.gz lazygit
sudo install lazygit -D -t /usr/local/bin/

sudo apt update && sudo apt install -y librewolf keepassxc \
  alsa-utils audacious mpv geany neovim mugshot \
  git 7zip qpwgraph imagemagick ffmpeg man-db \
  fonts-jetbrains-mono playerctl cava &&

wget https://github.com/ryanoasis/nerd-fonts/releases/download/v3.4.0/JetBrainsMono.zip &&

7z x JetBrainsMono.zip && mkdir -p ~/.fonts && mv *.tff ~/.fonts && \
  sudo fc-cache -fv && rm *.txt *.md
